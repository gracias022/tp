<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" minWidth="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS" minWidth="0">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" minWidth="0" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <Label fx:id="item" styleClass="order-item" text="$item" />
      <Label fx:id="quantity" styleClass="cell_small_label" text="$quantity" />
      <Label fx:id="address" styleClass="cell_small_label" text="$address" />
      <Label fx:id="date" styleClass="cell_small_label" text="$date" />
      <Label fx:id="status" styleClass="cell_small_label, order-status" text="$status" />
    </VBox>
  </GridPane>
</HBox>
